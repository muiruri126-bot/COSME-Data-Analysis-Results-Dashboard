# Environment
NODE_ENV=production
PORT=3001

# Database (PostgreSQL) — Use a cloud provider like Neon, Supabase, or Render
DATABASE_URL="postgresql://user:password@host:5432/cosme_procurement?schema=public"

# JWT — Change this to a strong random secret in production!
JWT_SECRET=change-this-to-a-strong-random-secret
JWT_EXPIRES_IN=8h
JWT_REFRESH_EXPIRES_IN=7d

# File uploads
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# CORS — Set to your Netlify domain
CORS_ORIGIN=https://your-site.netlify.app
